# ==============================================================================
# arXiv Alerter - 環境変数設定ファイル (config.env)
# ==============================================================================
# このファイルをコピーして config.env を作成してください。
# 機密情報（API_KEY, PASSWORD, メールアドレス）は環境変数またはSecrets推奨。
# ==============================================================================

# ------------------------------------------------------------------------------
# [必須] arXiv検索設定
# ※ settings.public.yaml でも設定可能。環境変数が優先されます。
# ------------------------------------------------------------------------------
# 検索キーワード（カンマ区切りでOR検索）
SEARCH_KEYWORDS="inflation, primordial black hole, axion"

# 検索カテゴリ（例: astro-ph.CO, gr-qc。'all'で全カテゴリ）
SEARCH_CATEGORY="astro-ph.CO, astro-ph.GA, gr-qc, hep-th, hep-ph"

# ------------------------------------------------------------------------------
# [必須] メール認証情報 ※TEST_MODE=true の場合は不要
# ※ GitHubでは Repository Secrets で設定してください
# ------------------------------------------------------------------------------
SMTP_USER="your_email@example.com"
SMTP_PASSWORD="your_smtp_password"
MAIL_FROM="your_email@example.com"
MAIL_TO="destination_email@example.com"

# ------------------------------------------------------------------------------
# [任意] SMTP設定
# ※ 未設定の場合は settings.public.yaml の mail.smtp_*_default を使用
# ------------------------------------------------------------------------------
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT="587"

# ------------------------------------------------------------------------------
# [任意] メール件名
# ※ 未設定の場合は settings.public.yaml の mail.subject_default を使用
# ------------------------------------------------------------------------------
MAIL_SUBJECT="【arXiv Alerter】注目論文が見つかりました"

# ------------------------------------------------------------------------------
# [任意] Gemini API設定
# ※ 未設定の場合、Geminiによる解説はスキップされます
# ※ GitHubでは Repository Secrets で設定してください
# ------------------------------------------------------------------------------
GEMINI_API_KEY="your_gemini_api_key"

# Gemini APIの1分あたり最大リクエスト数（レート制限対策）
# ※ 未設定の場合は settings.public.yaml の gemini.max_requests_per_minute を使用
# ※ 無料枠は約15 RPM程度が目安。0で無制限。
GEMINI_MAX_REQUESTS_PER_MINUTE="15"

# ------------------------------------------------------------------------------
# [任意] テストモード
# true: メール送信せず、本文を標準出力に表示（SMTP認証情報不要）
# ------------------------------------------------------------------------------
TEST_MODE="false"

# ------------------------------------------------------------------------------
# [任意] 設定ファイルパス（高度なカスタマイズ用）
# ※ デフォルトではスクリプトと同じディレクトリを参照
# ------------------------------------------------------------------------------
# SETTINGS_PUBLIC_PATH="./settings.public.yaml"
# GEMINI_PROMPT_PATH="./prompts/summary_ja.txt"
